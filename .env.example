# IACP Configuration Template
# Copy this file to .env and customize

# === WebSocket Relay Server ===
IACP_HOST=127.0.0.1
IACP_WS_PORT=8765
IACP_CLIENT_IDS=assistant-a,assistant-b
IACP_HEARTBEAT_INTERVAL_MS=15000
IACP_HEARTBEAT_TIMEOUT_MS=10000
IACP_MAX_MESSAGE_BYTES=1048576

# === Health Check ===
IACP_HEALTH_PORT=8081

# === Reliable Layer (client-side) ===
IACP_ACK_TIMEOUT_MS=500
IACP_MAX_RETRIES=3
IACP_RETRY_DELAYS_MS=1000,3000,7000
IACP_LRU_CACHE_SIZE=1000
IACP_LRU_CACHE_TTL_MS=300000
IACP_RECONNECT_BASE_MS=1000
IACP_RECONNECT_MAX_MS=30000
IACP_MAX_RECONNECT_ATTEMPTS=5

# === Monitoring (production) ===
IACP_LOG_LEVEL=info
IACP_LOG_FILE=/tmp/iacp/ws-server.log

# === Cutover ===
IACP_WS_SERVER_URL=ws://127.0.0.1:8765
IACP_DUAL_WRITE=false
IACP_FILE_CHANNEL_PATH=/tmp/iacp/messages
